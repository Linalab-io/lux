{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lux",
  "version": "0.1.0",
  "identifier": "com.linalab.lux",
  "build": {
    "beforeBuildCommand": "npm --prefix ../ui-src run build",
    "beforeDevCommand": "npm --prefix ../ui-src run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../ui-src/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lux Dashboard",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool"
  }
}
